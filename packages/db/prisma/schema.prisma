  objectifCroissance        String?   @map("objectif_croissance")
  objectifRevenus           String?   @map("objectif_revenus")
  objectifFiscal            String?   @map("objectif_fiscal")

  // Durabilité — pourcentages (0.0→1.0)
  pctTaxonomie              Float?    @map("pct_taxonomie")
  pctSfdrEnvironnemental    Float?    @map("pct_sfdr_environnemental")
  pctSfdrSocial             Float?    @map("pct_sfdr_social")

  // PAI — sociétés
  paiGesSocietes            Boolean   @default(false) @map("pai_ges_societes")
  paiBiodiversite           Boolean   @default(false) @map("pai_biodiversite")
  paiEau                    Boolean   @default(false) @map("pai_eau")
  paiDechets                Boolean   @default(false) @map("pai_dechets")
  paiSocialPersonnel        Boolean   @default(false) @map("pai_social_personnel")
  // PAI — actifs souverains
  paiGesSouverains          Boolean   @default(false) @map("pai_ges_souverains")
  paiNormesSociales         Boolean   @default(false) @map("pai_normes_sociales")
