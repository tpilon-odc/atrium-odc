// ──────────────────────────────────────────────────────────────────────────────

/// Arborescence de dossiers par cabinet. is_system = true → créé à l'onboarding, non supprimable.
model Folder {
  id        String   @id @default(uuid()) @db.Uuid
  cabinetId String   @map("cabinet_id") @db.Uuid
  name      String
  parentId  String?  @map("parent_id") @db.Uuid
  isSystem  Boolean  @default(false) @map("is_system")
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  cabinet     Cabinet      @relation(fields: [cabinetId], references: [id])
  parent      Folder?      @relation("tree", fields: [parentId], references: [id])
  children    Folder[]     @relation("tree")
  documents   Document[]
  folderRules FolderRule[]

  @@index([cabinetId])
  @@index([parentId])
  @@map("folders")
}

/// Tags du cabinet (cabinet_id nullable = tag système géré par platform_admin)
model Tag {
  id        String   @id @default(uuid()) @db.Uuid
  cabinetId String?  @map("cabinet_id") @db.Uuid
  name      String
  color     String?
  isSystem  Boolean  @default(false) @map("is_system")

  cabinet      Cabinet?      @relation(fields: [cabinetId], references: [id])
  documentTags DocumentTag[]

  @@unique([cabinetId, name])
  @@index([cabinetId])
  @@map("tags")
}

model DocumentTag {
  documentId String @map("document_id") @db.Uuid
  tagId      String @map("tag_id") @db.Uuid

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([documentId, tagId])
  @@map("document_tags")
}

