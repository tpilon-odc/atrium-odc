generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ──────────────────────────────────────────────────────────────────────────────
// ENUMS
// ──────────────────────────────────────────────────────────────────────────────

enum GlobalRole {
  cabinet_user
  platform_admin
  regulator
  chamber
}

enum SubscriptionStatus {
  active
  trial
  suspended
  cancelled
}

enum MemberRole {
  owner
  admin
  member
}

enum ComplianceItemType {
  doc
  text
  radio
  checkbox
}

enum AnswerStatus {
  draft
  submitted
}

enum ConditionOperator {
  eq
  not_eq
  in
  not_in
}

enum NotificationChannel {
  email
  in_app
}

enum ContactType {
  prospect
  client
  ancien_client
}

enum MaritalStatus {
  celibataire
  marie
  pacse
  divorce
  veuf
}

enum InteractionType {
  email
  appel
  rdv
  note
}

enum StorageMode {
  hosted
  external
}

enum EventType {
  RDV
  CALL
  TASK
  COMPLIANCE
}

enum EventStatus {
  PLANNED
  DONE
  CANCELLED
}

enum StorageProvider {
  aws
  gdrive
  sharepoint
  other
}

enum DocumentEntityType {
  cabinet
  contact
  product
  supplier
  compliance_answer
  message
}

enum ClusterRole {
  OWNER
  ADMIN
  MEMBER
}

enum ChannelType {
  ASYNC
  REALTIME
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
}

enum ExportStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
  EXPIRED
}

enum ShareEntityType {
  contact
  document
  collaborator_training
  cabinet_compliance
  cabinet
  compliance_item
}

enum GdprRequestType {
  ACCESS
  ERASURE
}

enum GdprRequestStatus {
  PENDING
  PROCESSING
  DONE
  REJECTED
}

// ──────────────────────────────────────────────────────────────────────────────
// AUTH & CABINETS
// ──────────────────────────────────────────────────────────────────────────────

/// Miroir de auth.users — créé automatiquement via trigger Supabase (voir sql/triggers.sql)
model User {
  id         String     @id @db.Uuid
  email      String     @unique
  firstName  String?    @map("first_name")
  lastName   String?    @map("last_name")
  avatarUrl  String?    @map("avatar_url")
  globalRole          GlobalRole @default(cabinet_user) @map("global_role")
  gdprAnonymizedAt    DateTime?  @map("gdpr_anonymized_at") @db.Timestamptz
  createdAt           DateTime   @default(now()) @map("created_at") @db.Timestamptz
  lastLogin           DateTime?  @map("last_login") @db.Timestamptz
  isActive            Boolean    @default(true) @map("is_active")

  cabinetMembers         CabinetMember[]
  complianceAnswers      CabinetComplianceAnswer[]
  suppliersCreated       Supplier[]
  supplierEdits          SupplierEdit[]
  productsCreated        Product[]
  productEdits           ProductEdit[]
  toolsCreated           Tool[]
  toolEdits              ToolEdit[]
  interactions           Interaction[]
  trainingCatalogCreated TrainingCatalog[]
  collaboratorTrainings  CollaboratorTraining[]
  sharesGrantedBy        Share[]                   @relation("GrantedBy")
  sharesGrantedTo        Share[]                   @relation("GrantedTo")
  shareViewLogs          ShareViewLog[]            @relation("ShareViewer")
  notifications          Notification[]
  eventsCreated          Event[]
  clustersCreated        Cluster[]
  channelsCreated        Channel[]
  messages               Message[]         @relation("MessageAuthor")
  messageReactions       MessageReaction[]
  messageReports         MessageReport[]
  exportJobsRequested    ExportJob[]
  consentRecords         ConsentRecord[]
  gdprRequestsMade       GdprRequest[]   @relation("RequestedBy")
  gdprRequestsProcessed  GdprRequest[]   @relation("ProcessedBy")

  @@map("users")
}

model Cabinet {
  id                 String             @id @default(uuid()) @db.Uuid
  name               String
  siret              String?
  oriasNumber        String?            @map("orias_number")
  subscriptionStatus SubscriptionStatus @default(trial) @map("subscription_status")
  settings           Json?              @db.JsonB
  description        String?            @db.Text
  city               String?
  website            String?
  logoUrl            String?            @map("logo_url")
  icsToken                String             @unique @default(uuid()) @map("ics_token") @db.Uuid
  deletionRequestedAt     DateTime?          @map("deletion_requested_at") @db.Timestamptz
  deletionScheduledAt     DateTime?          @map("deletion_scheduled_at") @db.Timestamptz
  createdAt               DateTime           @default(now()) @map("created_at") @db.Timestamptz

  members               CabinetMember[]
  complianceAnswers     CabinetComplianceAnswer[]
  complianceNotifs      ComplianceNotification[]
  cabinetSuppliers      CabinetSupplier[]
  supplierEdits         SupplierEdit[]
  supplierPublicRatings SupplierPublicRating[]
  cabinetProducts       CabinetProduct[]
  productEdits          ProductEdit[]
  productPublicRatings  ProductPublicRating[]
  cabinetTools          CabinetTool[]
  toolEdits             ToolEdit[]
  toolPublicRatings     ToolPublicRating[]
  contacts              Contact[]
  storageConfigs        CabinetStorageConfig[]
  documents             Document[]
  collaboratorTrainings CollaboratorTraining[]
  shares                Share[]
  notifications         Notification[]
  events                Event[]
  clusterMembers        ClusterMember[]
  messagesAuthored      Message[]         @relation("MessageCabinet")
  messageReactions      MessageReaction[]
  folders               Folder[]
  tags                  Tag[]
  exportJobs            ExportJob[]
  gdprRequests          GdprRequest[]

  @@map("cabinets")
}

model CabinetMember {
  id                String    @id @default(uuid()) @db.Uuid
  cabinetId         String    @map("cabinet_id") @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  role              MemberRole
  canManageSuppliers Boolean  @default(false) @map("can_manage_suppliers")
  canManageProducts  Boolean  @default(false) @map("can_manage_products")
  canManageContacts  Boolean  @default(false) @map("can_manage_contacts")
  deletedAt         DateTime? @map("deleted_at") @db.Timestamptz

  cabinet Cabinet @relation(fields: [cabinetId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([cabinetId, userId])
  @@index([cabinetId])
  @@map("cabinet_members")
}

model ConsentRecord {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  version     String
  acceptedAt  DateTime @default(now()) @map("accepted_at") @db.Timestamptz
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("consent_records")
}

model GdprRequest {
  id           String            @id @default(uuid()) @db.Uuid
  cabinetId    String            @map("cabinet_id") @db.Uuid
  requestedBy  String            @map("requested_by") @db.Uuid
  type         GdprRequestType
  status       GdprRequestStatus @default(PENDING)
  message      String?
  processedBy  String?           @map("processed_by") @db.Uuid
  processedAt  DateTime?         @map("processed_at") @db.Timestamptz
  response     String?
  exportPath   String?           @map("export_path")
  createdAt    DateTime          @default(now()) @map("created_at") @db.Timestamptz

  cabinet     Cabinet @relation(fields: [cabinetId], references: [id])
  requester   User    @relation("RequestedBy", fields: [requestedBy], references: [id])
  processor   User?   @relation("ProcessedBy", fields: [processedBy], references: [id])

  @@index([cabinetId])
  @@index([status])
  @@map("gdpr_requests")
}

// ──────────────────────────────────────────────────────────────────────────────
// CONFORMITÉ
// ──────────────────────────────────────────────────────────────────────────────

model CompliancePhase {
  id          String   @id @default(uuid()) @db.Uuid
  label       String
  description String?
  order       Int
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  items ComplianceItem[]

  @@map("compliance_phases")
}

model ComplianceItem {
  id                 String             @id @default(uuid()) @db.Uuid
  phaseId            String             @map("phase_id") @db.Uuid
  label              String
  type               ComplianceItemType
  config             Json               @db.JsonB
  isRequired         Boolean            @default(true) @map("is_required")
  validityMonths     Int?               @map("validity_months")
  alertBeforeDays    Int[]              @map("alert_before_days")
  dueDaysAfterSignup Int?               @map("due_days_after_signup")
  order              Int

  phase      CompliancePhase           @relation(fields: [phaseId], references: [id])
  conditions ComplianceCondition[]     @relation("ConditionedItem")
  dependedBy ComplianceCondition[]     @relation("DependsOnItem")
  answers    CabinetComplianceAnswer[]

  @@index([phaseId])
  @@map("compliance_items")
}

model ComplianceCondition {
  id              String            @id @default(uuid()) @db.Uuid
  itemId          String            @map("item_id") @db.Uuid
  dependsOnItemId String            @map("depends_on_item_id") @db.Uuid
  operator        ConditionOperator
  expectedValue   String            @map("expected_value")

  item      ComplianceItem @relation("ConditionedItem", fields: [itemId], references: [id])
  dependsOn ComplianceItem @relation("DependsOnItem", fields: [dependsOnItemId], references: [id])

  @@index([itemId])
  @@map("compliance_conditions")
}

model CabinetComplianceAnswer {
  id          String       @id @default(uuid()) @db.Uuid
  cabinetId   String       @map("cabinet_id") @db.Uuid
  itemId      String       @map("item_id") @db.Uuid
  answeredBy  String       @map("answered_by") @db.Uuid
  value       Json         @db.JsonB
  status      AnswerStatus @default(draft)
  submittedAt DateTime?    @map("submitted_at") @db.Timestamptz
  expiresAt   DateTime?    @map("expires_at") @db.Timestamptz
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime?    @map("deleted_at") @db.Timestamptz

  cabinet       Cabinet                @relation(fields: [cabinetId], references: [id])
  item          ComplianceItem         @relation(fields: [itemId], references: [id])
  user          User                   @relation(fields: [answeredBy], references: [id])
  notifications ComplianceNotification[]
  events        Event[]

  @@unique([cabinetId, itemId])
  @@index([cabinetId])
  @@index([expiresAt])
  @@map("cabinet_compliance_answers")
}

model ComplianceNotification {
  id         String              @id @default(uuid()) @db.Uuid
  cabinetId  String              @map("cabinet_id") @db.Uuid
  answerId   String              @map("answer_id") @db.Uuid
  daysBefore Int                 @map("days_before")
  channel    NotificationChannel
  sentAt     DateTime            @map("sent_at") @db.Timestamptz

  cabinet Cabinet                 @relation(fields: [cabinetId], references: [id])
  answer  CabinetComplianceAnswer @relation(fields: [answerId], references: [id])

  @@index([cabinetId])
  @@index([answerId, daysBefore])
  @@map("compliance_notifications")
}

// ──────────────────────────────────────────────────────────────────────────────
// BASE COMMUNAUTAIRE — FOURNISSEURS
// ──────────────────────────────────────────────────────────────────────────────

model Supplier {
  id              String    @id @default(uuid()) @db.Uuid
  name            String
  description     String?
  category        String?
  website         String?
  email           String?
  phone           String?
  createdBy       String    @map("created_by") @db.Uuid
  avgPublicRating Float?    @map("avg_public_rating")
  isVerified      Boolean   @default(false) @map("is_verified")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz

  creator          User                   @relation(fields: [createdBy], references: [id])
  edits            SupplierEdit[]
  cabinetSuppliers CabinetSupplier[]
  publicRatings    SupplierPublicRating[]
  productLinks     ProductSupplier[]

  @@index([createdAt])
  @@map("suppliers")
}

model SupplierEdit {
  id         String   @id @default(uuid()) @db.Uuid
  supplierId String   @map("supplier_id") @db.Uuid
  editedBy   String   @map("edited_by") @db.Uuid
  cabinetId  String   @map("cabinet_id") @db.Uuid
  diff       Json     @db.JsonB
  editedAt   DateTime @default(now()) @map("edited_at") @db.Timestamptz

  supplier Supplier @relation(fields: [supplierId], references: [id])
  editor   User     @relation(fields: [editedBy], references: [id])
  cabinet  Cabinet  @relation(fields: [cabinetId], references: [id])

  @@index([supplierId])
  @@map("supplier_edits")
}

model CabinetSupplier {
  id            String    @id @default(uuid()) @db.Uuid
  cabinetId     String    @map("cabinet_id") @db.Uuid
  supplierId    String    @map("supplier_id") @db.Uuid
  isActive      Boolean   @default(true) @map("is_active")
  privateRating Int?      @map("private_rating")
  privateNote   String?   @map("private_note")
  internalTags  String[]  @map("internal_tags")
  customFields  Json?     @db.JsonB @map("custom_fields")
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz

  cabinet  Cabinet  @relation(fields: [cabinetId], references: [id])
  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@unique([cabinetId, supplierId])
  @@index([cabinetId])
  @@map("cabinet_suppliers")
}

/// 1 note publique par cabinet par fournisseur — avg_public_rating recalculé par trigger
model SupplierPublicRating {
  id         String   @id @default(uuid()) @db.Uuid
  supplierId String   @map("supplier_id") @db.Uuid
  cabinetId  String   @map("cabinet_id") @db.Uuid
  rating     Int
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  supplier Supplier @relation(fields: [supplierId], references: [id])
  cabinet  Cabinet  @relation(fields: [cabinetId], references: [id])

  @@unique([supplierId, cabinetId])
  @@index([supplierId])
  @@map("supplier_public_ratings")
}

// ──────────────────────────────────────────────────────────────────────────────
// BASE COMMUNAUTAIRE — PRODUITS
// ──────────────────────────────────────────────────────────────────────────────

model Product {
  id              String    @id @default(uuid()) @db.Uuid
  name            String
  description     String?
  category        String?
  website         String?
  createdBy       String    @map("created_by") @db.Uuid
  avgPublicRating Float?    @map("avg_public_rating")
  isVerified      Boolean   @default(false) @map("is_verified")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz

  creator         User                  @relation(fields: [createdBy], references: [id])
  edits           ProductEdit[]
  cabinetProducts CabinetProduct[]
  publicRatings   ProductPublicRating[]
  supplierLinks   ProductSupplier[]

  @@index([createdAt])
  @@map("products")
}

model ProductEdit {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  editedBy  String   @map("edited_by") @db.Uuid
  cabinetId String   @map("cabinet_id") @db.Uuid
  diff      Json     @db.JsonB
  editedAt  DateTime @default(now()) @map("edited_at") @db.Timestamptz

  product Product @relation(fields: [productId], references: [id])
  editor  User    @relation(fields: [editedBy], references: [id])
  cabinet Cabinet @relation(fields: [cabinetId], references: [id])

  @@index([productId])
  @@map("product_edits")
}

model CabinetProduct {
  id               String    @id @default(uuid()) @db.Uuid
  cabinetId        String    @map("cabinet_id") @db.Uuid
  productId        String    @map("product_id") @db.Uuid
  isActive         Boolean   @default(true) @map("is_active")
  isCommercialized Boolean   @default(false) @map("is_commercialized")
  supplierId       String?   @map("supplier_id") @db.Uuid
  privateRating    Int?      @map("private_rating")
  privateNote      String?   @map("private_note")
  internalTags     String[]  @map("internal_tags")
  customFields     Json?     @db.JsonB @map("custom_fields")
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz

  cabinet Cabinet @relation(fields: [cabinetId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([cabinetId, productId])
  @@index([cabinetId])
  @@map("cabinet_products")
}

/// Table pivot produit ↔ fournisseur (relation communautaire)
model ProductSupplier {
  id         String @id @default(uuid()) @db.Uuid
  productId  String @map("product_id") @db.Uuid
  supplierId String @map("supplier_id") @db.Uuid

  product  Product  @relation(fields: [productId], references: [id])
  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@unique([productId, supplierId])
  @@map("product_suppliers")
}

/// 1 note publique par cabinet par produit — avg_public_rating recalculé par trigger
model ProductPublicRating {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  cabinetId String   @map("cabinet_id") @db.Uuid
  rating    Int
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  product Product @relation(fields: [productId], references: [id])
  cabinet Cabinet @relation(fields: [cabinetId], references: [id])

  @@unique([productId, cabinetId])
  @@index([productId])
  @@map("product_public_ratings")
}

// ──────────────────────────────────────────────────────────────────────────────
// BASE COMMUNAUTAIRE — OUTILS
// ──────────────────────────────────────────────────────────────────────────────

model Tool {
  id              String    @id @default(uuid()) @db.Uuid
  name            String
  description     String?
  category        String?
  url             String?
  createdBy       String    @map("created_by") @db.Uuid
  avgPublicRating Float?    @map("avg_public_rating")
  isVerified      Boolean   @default(false) @map("is_verified")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz

  creator      User               @relation(fields: [createdBy], references: [id])
  edits        ToolEdit[]
  cabinetTools CabinetTool[]
  publicRatings ToolPublicRating[]

  @@index([createdAt])
  @@map("tools")
}

model ToolEdit {
  id        String   @id @default(uuid()) @db.Uuid
  toolId    String   @map("tool_id") @db.Uuid
  editedBy  String   @map("edited_by") @db.Uuid
  cabinetId String   @map("cabinet_id") @db.Uuid
  diff      Json     @db.JsonB
  editedAt  DateTime @default(now()) @map("edited_at") @db.Timestamptz

  tool    Tool    @relation(fields: [toolId], references: [id])
  editor  User    @relation(fields: [editedBy], references: [id])
  cabinet Cabinet @relation(fields: [cabinetId], references: [id])

  @@index([toolId])
  @@map("tool_edits")
}

model CabinetTool {
  id            String    @id @default(uuid()) @db.Uuid
  cabinetId     String    @map("cabinet_id") @db.Uuid
  toolId        String    @map("tool_id") @db.Uuid
  isActive      Boolean   @default(true) @map("is_active")
  privateRating Int?      @map("private_rating")
  privateNote   String?   @map("private_note")
  internalTags  String[]  @map("internal_tags")
  customFields  Json?     @db.JsonB @map("custom_fields")
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz

  cabinet Cabinet @relation(fields: [cabinetId], references: [id])
  tool    Tool    @relation(fields: [toolId], references: [id])

  @@unique([cabinetId, toolId])
  @@index([cabinetId])
  @@map("cabinet_tools")
}

/// 1 note publique par cabinet par outil — avg_public_rating recalculé par trigger
model ToolPublicRating {
  id        String   @id @default(uuid()) @db.Uuid
  toolId    String   @map("tool_id") @db.Uuid
  cabinetId String   @map("cabinet_id") @db.Uuid
  rating    Int
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tool    Tool    @relation(fields: [toolId], references: [id])
  cabinet Cabinet @relation(fields: [cabinetId], references: [id])

  @@unique([toolId, cabinetId])
  @@index([toolId])
  @@map("tool_public_ratings")
}

// ──────────────────────────────────────────────────────────────────────────────
// CRM
// ──────────────────────────────────────────────────────────────────────────────

model Contact {
  id            String         @id @default(uuid()) @db.Uuid
  cabinetId     String         @map("cabinet_id") @db.Uuid
  firstName     String?        @map("first_name")
  lastName      String         @map("last_name")
  email         String?
  email2        String?        @map("email2")
  phone         String?
  phone2        String?        @map("phone2")
  type          ContactType
  birthDate     DateTime?      @map("birth_date") @db.Date
  profession    String?
  address       String?
  city          String?
  postalCode    String?        @map("postal_code")
  country       String?        @default("France")
  maritalStatus MaritalStatus? @map("marital_status")
  dependents    Int?
  metadata      Json?          @db.JsonB
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz
  deletedAt     DateTime?      @map("deleted_at") @db.Timestamptz

  cabinet      Cabinet       @relation(fields: [cabinetId], references: [id])
  interactions Interaction[]
  events       Event[]

  @@index([cabinetId])
  @@map("contacts")
}

model Interaction {
  id          String          @id @default(uuid()) @db.Uuid
  contactId   String          @map("contact_id") @db.Uuid
  userId      String          @map("user_id") @db.Uuid
  type        InteractionType
  note        String?
  occurredAt  DateTime        @map("occurred_at") @db.Timestamptz
  deletedAt   DateTime?       @map("deleted_at") @db.Timestamptz

  contact Contact @relation(fields: [contactId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([contactId])
  @@map("interactions")
}

// ──────────────────────────────────────────────────────────────────────────────
// GED
// ──────────────────────────────────────────────────────────────────────────────

model CabinetStorageConfig {
  id        String          @id @default(uuid()) @db.Uuid
  cabinetId String          @map("cabinet_id") @db.Uuid
  provider  StorageProvider
  label     String
  baseUrl   String          @map("base_url")
  createdAt DateTime        @default(now()) @map("created_at") @db.Timestamptz

  cabinet   Cabinet    @relation(fields: [cabinetId], references: [id])
  documents Document[]

  @@index([cabinetId])
  @@map("cabinet_storage_config")
}

model Document {
  id               String      @id @default(uuid()) @db.Uuid
  cabinetId        String      @map("cabinet_id") @db.Uuid
  uploadedBy       String      @map("uploaded_by") @db.Uuid
  name             String
  description      String?
  storageMode      StorageMode @map("storage_mode")
  storagePath      String?     @map("storage_path")
  externalConfigId String?     @map("external_config_id") @db.Uuid
  externalPath     String?     @map("external_path")
  mimeType         String?     @map("mime_type")
  sizeBytes        BigInt?     @map("size_bytes")
  folderId         String?     @map("folder_id") @db.Uuid
  createdAt        DateTime    @default(now()) @map("created_at") @db.Timestamptz
  deletedAt        DateTime?   @map("deleted_at") @db.Timestamptz

  cabinet        Cabinet               @relation(fields: [cabinetId], references: [id])
  externalConfig CabinetStorageConfig? @relation(fields: [externalConfigId], references: [id])
  folder         Folder?               @relation(fields: [folderId], references: [id])
  links          DocumentLink[]
  certificates   CollaboratorTraining[]
  tags           DocumentTag[]

  @@index([cabinetId])
  @@index([folderId])
  @@map("documents")
}

model DocumentLink {
  id         String             @id @default(uuid()) @db.Uuid
  documentId String             @map("document_id") @db.Uuid
  entityType DocumentEntityType @map("entity_type")
  entityId   String             @map("entity_id") @db.Uuid
  label      String?

  document Document @relation(fields: [documentId], references: [id])

  @@index([documentId])
  @@index([entityType, entityId])
  @@map("document_links")
}

// ──────────────────────────────────────────────────────────────────────────────
// GED — DOSSIERS & TAGS
// ──────────────────────────────────────────────────────────────────────────────

/// Arborescence de dossiers par cabinet. is_system = true → créé à l'onboarding, non supprimable.
model Folder {
  id        String   @id @default(uuid()) @db.Uuid
  cabinetId String   @map("cabinet_id") @db.Uuid
  name      String
  parentId  String?  @map("parent_id") @db.Uuid
  isSystem  Boolean  @default(false) @map("is_system")
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  cabinet   Cabinet    @relation(fields: [cabinetId], references: [id])
  parent    Folder?    @relation("tree", fields: [parentId], references: [id])
  children  Folder[]   @relation("tree")
  documents Document[]

  @@index([cabinetId])
  @@index([parentId])
  @@map("folders")
}

/// Tags du cabinet (cabinet_id nullable = tag système géré par platform_admin)
model Tag {
  id        String   @id @default(uuid()) @db.Uuid
  cabinetId String?  @map("cabinet_id") @db.Uuid
  name      String
  color     String?
  isSystem  Boolean  @default(false) @map("is_system")

  cabinet      Cabinet?      @relation(fields: [cabinetId], references: [id])
  documentTags DocumentTag[]

  @@unique([cabinetId, name])
  @@index([cabinetId])
  @@map("tags")
}

model DocumentTag {
  documentId String @map("document_id") @db.Uuid
  tagId      String @map("tag_id") @db.Uuid

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([documentId, tagId])
  @@map("document_tags")
}

// ──────────────────────────────────────────────────────────────────────────────
// EXPORT GLOBAL
// ──────────────────────────────────────────────────────────────────────────────

model ExportJob {
  id          String       @id @default(uuid()) @db.Uuid
  cabinetId   String       @map("cabinet_id") @db.Uuid
  requestedBy String       @map("requested_by") @db.Uuid
  status      ExportStatus @default(PENDING)
  storagePath String?      @map("storage_path")
  expiresAt   DateTime?    @map("expires_at") @db.Timestamptz
  error       String?
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz
  completedAt DateTime?    @map("completed_at") @db.Timestamptz

  cabinet   Cabinet @relation(fields: [cabinetId], references: [id])
  requester User    @relation(fields: [requestedBy], references: [id])

  @@index([cabinetId])
  @@index([status])
  @@map("export_jobs")
}

// ──────────────────────────────────────────────────────────────────────────────
// FORMATIONS
// ──────────────────────────────────────────────────────────────────────────────

model TrainingCatalog {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  organizer    String?
  category     String?
  defaultHours Float?   @map("default_hours")
  createdBy    String   @map("created_by") @db.Uuid
  isVerified   Boolean  @default(false) @map("is_verified")
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz

  creator               User                   @relation(fields: [createdBy], references: [id])
  collaboratorTrainings CollaboratorTraining[]

  @@map("training_catalog")
}

model CollaboratorTraining {
  id                    String    @id @default(uuid()) @db.Uuid
  cabinetId             String    @map("cabinet_id") @db.Uuid
  userId                String    @map("user_id") @db.Uuid
  trainingId            String    @map("training_id") @db.Uuid
  trainingDate          DateTime  @map("training_date") @db.Date
  trainingDateEnd       DateTime? @map("training_date_end") @db.Date
  hoursCompleted        Float?    @map("hours_completed")
  certificateDocumentId String?   @map("certificate_document_id") @db.Uuid
  notes                 String?
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz
  deletedAt             DateTime? @map("deleted_at") @db.Timestamptz

  cabinet     Cabinet         @relation(fields: [cabinetId], references: [id])
  user        User            @relation(fields: [userId], references: [id])
  training    TrainingCatalog @relation(fields: [trainingId], references: [id])
  certificate Document?       @relation(fields: [certificateDocumentId], references: [id])

  @@index([cabinetId])
  @@index([userId])
  @@map("collaborator_trainings")
}

// ──────────────────────────────────────────────────────────────────────────────
// PARTAGE INTER-UTILISATEURS
// ──────────────────────────────────────────────────────────────────────────────

model Share {
  id         String          @id @default(uuid()) @db.Uuid
  cabinetId  String          @map("cabinet_id") @db.Uuid
  grantedBy  String          @map("granted_by") @db.Uuid
  grantedTo  String          @map("granted_to") @db.Uuid
  entityType ShareEntityType @map("entity_type")
  entityId   String?         @map("entity_id") @db.Uuid
  isActive   Boolean         @default(true) @map("is_active")
  createdAt  DateTime        @default(now()) @map("created_at") @db.Timestamptz
  revokedAt  DateTime?       @map("revoked_at") @db.Timestamptz

  cabinet     Cabinet @relation(fields: [cabinetId], references: [id])
  granterUser User    @relation("GrantedBy", fields: [grantedBy], references: [id])
  recipientUser User  @relation("GrantedTo", fields: [grantedTo], references: [id])
  viewLogs    ShareViewLog[]

  @@index([cabinetId])
  @@index([grantedTo, isActive])
  @@map("shares")
}

model ShareViewLog {
  id        String   @id @default(uuid()) @db.Uuid
  shareId   String   @map("share_id") @db.Uuid
  viewerId  String   @map("viewer_id") @db.Uuid
  viewedAt  DateTime @default(now()) @map("viewed_at") @db.Timestamptz
  ipAddress String?  @map("ip_address")

  share  Share @relation(fields: [shareId], references: [id])
  viewer User  @relation("ShareViewer", fields: [viewerId], references: [id])

  @@index([shareId])
  @@index([viewerId])
  @@map("share_view_logs")
}

// ──────────────────────────────────────────────────────────────────────────────
// NOTIFICATIONS IN-APP
// ──────────────────────────────────────────────────────────────────────────────

model Notification {
  id         String   @id @default(uuid()) @db.Uuid
  cabinetId  String   @map("cabinet_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  type       String   // "compliance_expiring" | "compliance_expired"
  title      String
  message    String
  entityType String   @map("entity_type")  // "compliance_answer"
  entityId   String   @map("entity_id") @db.Uuid
  isRead     Boolean  @default(false) @map("is_read")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  cabinet Cabinet @relation(fields: [cabinetId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([cabinetId])
  @@index([userId, isRead])
  @@map("notifications")
}

// ──────────────────────────────────────────────────────────────────────────────
// AGENDA
// ──────────────────────────────────────────────────────────────────────────────

model Event {
  id                 String      @id @default(uuid()) @db.Uuid
  cabinetId          String      @map("cabinet_id") @db.Uuid
  createdBy          String      @map("created_by") @db.Uuid
  contactId          String?     @map("contact_id") @db.Uuid
  title              String
  description        String?
  type               EventType
  status             EventStatus @default(PLANNED)
  startAt            DateTime    @map("start_at") @db.Timestamptz
  endAt              DateTime    @map("end_at") @db.Timestamptz
  allDay             Boolean     @default(false) @map("all_day")
  location           String?
  complianceAnswerId String?     @map("compliance_answer_id") @db.Uuid
  isRecurring        Boolean     @default(false) @map("is_recurring")
  recurrenceRule     String?     @map("recurrence_rule")
  deletedAt          DateTime?   @map("deleted_at") @db.Timestamptz
  createdAt          DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  cabinet          Cabinet                  @relation(fields: [cabinetId], references: [id])
  creator          User                     @relation(fields: [createdBy], references: [id])
  contact          Contact?                 @relation(fields: [contactId], references: [id])
  complianceAnswer CabinetComplianceAnswer? @relation(fields: [complianceAnswerId], references: [id])

  @@index([cabinetId])
  @@index([startAt])
  @@index([contactId])
  @@map("events")
}

// ──────────────────────────────────────────────────────────────────────────────
// CLUSTERS — espaces communautaires inter-cabinets
// ──────────────────────────────────────────────────────────────────────────────

model Cluster {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?
  createdBy   String   @map("created_by") @db.Uuid
  isPublic    Boolean  @default(true) @map("is_public")
  isVerified  Boolean  @default(false) @map("is_verified")
  avatarUrl   String?  @map("avatar_url")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  creator  User            @relation(fields: [createdBy], references: [id])
  members  ClusterMember[]
  channels Channel[]

  @@index([isPublic])
  @@map("clusters")
}

model ClusterMember {
  id        String      @id @default(uuid()) @db.Uuid
  clusterId String      @map("cluster_id") @db.Uuid
  cabinetId String      @map("cabinet_id") @db.Uuid
  role      ClusterRole @default(MEMBER)
  joinedAt  DateTime    @default(now()) @map("joined_at") @db.Timestamptz
  invitedBy String?     @map("invited_by") @db.Uuid

  cluster Cluster @relation(fields: [clusterId], references: [id])
  cabinet Cabinet @relation(fields: [cabinetId], references: [id])

  @@unique([clusterId, cabinetId])
  @@index([cabinetId])
  @@map("cluster_members")
}

model Channel {
  id            String      @id @default(uuid()) @db.Uuid
  clusterId     String      @map("cluster_id") @db.Uuid
  name          String
  type          ChannelType @default(ASYNC)
  isPrivate     Boolean     @default(false) @map("is_private")
  createdBy     String      @map("created_by") @db.Uuid
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz
  lastMessageAt DateTime?   @map("last_message_at") @db.Timestamptz

  cluster  Cluster   @relation(fields: [clusterId], references: [id])
  creator  User      @relation(fields: [createdBy], references: [id])
  messages Message[]

  @@index([clusterId])
  @@map("channels")
}

model Message {
  id              String    @id @default(uuid()) @db.Uuid
  channelId       String    @map("channel_id") @db.Uuid
  authorUserId    String    @map("author_user_id") @db.Uuid
  authorCabinetId String    @map("author_cabinet_id") @db.Uuid
  content         String
  parentId        String?   @map("parent_id") @db.Uuid
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  channel       Channel           @relation(fields: [channelId], references: [id])
  authorUser    User              @relation("MessageAuthor", fields: [authorUserId], references: [id])
  authorCabinet Cabinet           @relation("MessageCabinet", fields: [authorCabinetId], references: [id])
  parent        Message?          @relation("Thread", fields: [parentId], references: [id])
  replies       Message[]         @relation("Thread")
  reactions     MessageReaction[]
  reports       MessageReport[]

  @@index([channelId])
  @@index([parentId])
  @@index([createdAt])
  @@map("messages")
}

model MessageReaction {
  id        String @id @default(uuid()) @db.Uuid
  messageId String @map("message_id") @db.Uuid
  userId    String @map("user_id") @db.Uuid
  cabinetId String @map("cabinet_id") @db.Uuid
  emoji     String

  message Message @relation(fields: [messageId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
  cabinet Cabinet @relation(fields: [cabinetId], references: [id])

  @@unique([messageId, userId, emoji])
  @@map("message_reactions")
}

model MessageReport {
  id         String       @id @default(uuid()) @db.Uuid
  messageId  String       @map("message_id") @db.Uuid
  reportedBy String       @map("reported_by") @db.Uuid
  reason     String
  status     ReportStatus @default(PENDING)
  createdAt  DateTime     @default(now()) @map("created_at") @db.Timestamptz

  message  Message @relation(fields: [messageId], references: [id])
  reporter User    @relation(fields: [reportedBy], references: [id])

  @@index([status])
  @@map("message_reports")
}
