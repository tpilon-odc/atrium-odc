  expiresAt   DateTime?    @map("expires_at") @db.Timestamptz
  error       String?
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz
  completedAt DateTime?    @map("completed_at") @db.Timestamptz

  cabinet   Cabinet @relation(fields: [cabinetId], references: [id])
  requester User    @relation(fields: [requestedBy], references: [id])

  @@index([cabinetId])
  @@index([status])
  @@map("export_jobs")
}

// ──────────────────────────────────────────────────────────────────────────────
// FORMATIONS
// ──────────────────────────────────────────────────────────────────────────────

/// Catégories de formations paramétrables par l'administrateur plateforme
model TrainingCategory {
  id                   String   @id @default(uuid()) @db.Uuid
  name                 String
  code                 String   @unique
  order                Int      @default(0)
  isActive             Boolean  @default(true) @map("is_active")
  requiredHours        Float?   @map("required_hours")
  requiredHoursPeriod  Int?     @default(1) @map("required_hours_period")

  trainingCatalogs      TrainingCatalog[]
  collaboratorHours     CollaboratorTrainingHours[]

  @@map("training_categories")
}

model TrainingCatalog {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  organizer    String?
  category     String?
  categoryId   String?  @map("category_id") @db.Uuid
  defaultHours Float?   @map("default_hours")
  createdBy    String   @map("created_by") @db.Uuid
  isVerified   Boolean  @default(false) @map("is_verified")
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz

  creator               User                   @relation(fields: [createdBy], references: [id])
  trainingCategory      TrainingCategory?      @relation(fields: [categoryId], references: [id])
  collaboratorTrainings CollaboratorTraining[]

  @@map("training_catalog")
}

model CollaboratorTraining {
  id                    String    @id @default(uuid()) @db.Uuid
  cabinetId             String    @map("cabinet_id") @db.Uuid
  userId                String?   @map("user_id") @db.Uuid
  memberId              String?   @map("member_id") @db.Uuid
  trainingId            String    @map("training_id") @db.Uuid
  trainingDate          DateTime  @map("training_date") @db.Date
  trainingDateEnd       DateTime? @map("training_date_end") @db.Date
  hoursCompleted        Float?    @map("hours_completed")
  certificateDocumentId String?   @map("certificate_document_id") @db.Uuid
  notes                 String?
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz
  deletedAt             DateTime? @map("deleted_at") @db.Timestamptz

  cabinet     Cabinet         @relation(fields: [cabinetId], references: [id])
  user        User?           @relation(fields: [userId], references: [id])
  member      CabinetMember?  @relation(fields: [memberId], references: [id])
  training    TrainingCatalog @relation(fields: [trainingId], references: [id])
  certificate Document?       @relation(fields: [certificateDocumentId], references: [id])
  categoryHours CollaboratorTrainingHours[]

  @@index([cabinetId])
  @@index([userId])
  @@map("collaborator_trainings")
}

/// Heures par catégorie réglementaire pour une formation suivie
model CollaboratorTrainingHours {
  id           String  @id @default(uuid()) @db.Uuid
  trainingRecordId String @map("training_record_id") @db.Uuid
  categoryId   String  @map("category_id") @db.Uuid
  hours        Float

  trainingRecord CollaboratorTraining @relation(fields: [trainingRecordId], references: [id], onDelete: Cascade)
  category       TrainingCategory     @relation(fields: [categoryId], references: [id])

  @@unique([trainingRecordId, categoryId])
  @@map("collaborator_training_hours")
}

// ──────────────────────────────────────────────────────────────────────────────
// PARTAGE INTER-UTILISATEURS
// ──────────────────────────────────────────────────────────────────────────────

model Share {
  id         String          @id @default(uuid()) @db.Uuid
  cabinetId  String          @map("cabinet_id") @db.Uuid
  grantedBy  String          @map("granted_by") @db.Uuid
  grantedTo  String          @map("granted_to") @db.Uuid
  entityType ShareEntityType @map("entity_type")
  entityId   String?         @map("entity_id") @db.Uuid
  isActive   Boolean         @default(true) @map("is_active")
  createdAt  DateTime        @default(now()) @map("created_at") @db.Timestamptz
  revokedAt  DateTime?       @map("revoked_at") @db.Timestamptz

  cabinet     Cabinet @relation(fields: [cabinetId], references: [id])
  granterUser User    @relation("GrantedBy", fields: [grantedBy], references: [id])
  recipientUser User  @relation("GrantedTo", fields: [grantedTo], references: [id])
  viewLogs    ShareViewLog[]

  @@index([cabinetId])
  @@index([grantedTo, isActive])
  @@map("shares")
}

model ShareViewLog {
  id        String   @id @default(uuid()) @db.Uuid
  shareId   String   @map("share_id") @db.Uuid
  viewerId  String   @map("viewer_id") @db.Uuid
  viewedAt  DateTime @default(now()) @map("viewed_at") @db.Timestamptz
  ipAddress String?  @map("ip_address")

  share  Share @relation(fields: [shareId], references: [id])
  viewer User  @relation("ShareViewer", fields: [viewerId], references: [id])

  @@index([shareId])
  @@index([viewerId])
  @@map("share_view_logs")
}

// ──────────────────────────────────────────────────────────────────────────────
// NOTIFICATIONS IN-APP
// ──────────────────────────────────────────────────────────────────────────────

model Notification {
  id         String   @id @default(uuid()) @db.Uuid
  cabinetId  String   @map("cabinet_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  type       String   // "compliance_expiring" | "compliance_expired"
  title      String
  message    String
  entityType String   @map("entity_type")  // "compliance_answer"
  entityId   String   @map("entity_id") @db.Uuid
  isRead     Boolean  @default(false) @map("is_read")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  cabinet Cabinet @relation(fields: [cabinetId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([cabinetId])
  @@index([userId, isRead])
  @@map("notifications")
}

// ──────────────────────────────────────────────────────────────────────────────
// AGENDA
// ──────────────────────────────────────────────────────────────────────────────

model Event {
  id                 String      @id @default(uuid()) @db.Uuid
  cabinetId          String      @map("cabinet_id") @db.Uuid
  createdBy          String      @map("created_by") @db.Uuid
  contactId          String?     @map("contact_id") @db.Uuid
  title              String
  description        String?
  type               EventType
  status             EventStatus @default(PLANNED)
  startAt            DateTime    @map("start_at") @db.Timestamptz
  endAt              DateTime    @map("end_at") @db.Timestamptz
  allDay             Boolean     @default(false) @map("all_day")
  location           String?
  complianceAnswerId String?     @map("compliance_answer_id") @db.Uuid
  isRecurring        Boolean     @default(false) @map("is_recurring")
  recurrenceRule     String?     @map("recurrence_rule")
  deletedAt          DateTime?   @map("deleted_at") @db.Timestamptz
  createdAt          DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  cabinet          Cabinet                  @relation(fields: [cabinetId], references: [id])
  creator          User                     @relation(fields: [createdBy], references: [id])
  contact          Contact?                 @relation(fields: [contactId], references: [id])
  complianceAnswer CabinetComplianceAnswer? @relation(fields: [complianceAnswerId], references: [id])

  @@index([cabinetId])
  @@index([startAt])
  @@index([contactId])
  @@map("events")
}

// ──────────────────────────────────────────────────────────────────────────────
// CLUSTERS — espaces communautaires inter-cabinets
// ──────────────────────────────────────────────────────────────────────────────

model Cluster {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?
  createdBy   String   @map("created_by") @db.Uuid
  isPublic    Boolean  @default(true) @map("is_public")
  isVerified  Boolean  @default(false) @map("is_verified")
  avatarUrl   String?  @map("avatar_url")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  creator  User            @relation(fields: [createdBy], references: [id])
  members  ClusterMember[]
  channels Channel[]

  @@index([isPublic])
  @@map("clusters")
}

model ClusterMember {
  id        String      @id @default(uuid()) @db.Uuid
  clusterId String      @map("cluster_id") @db.Uuid
  cabinetId String      @map("cabinet_id") @db.Uuid
  role      ClusterRole @default(MEMBER)
  joinedAt  DateTime    @default(now()) @map("joined_at") @db.Timestamptz
  invitedBy String?     @map("invited_by") @db.Uuid

  cluster Cluster @relation(fields: [clusterId], references: [id])
  cabinet Cabinet @relation(fields: [cabinetId], references: [id])

  @@unique([clusterId, cabinetId])
  @@index([cabinetId])
  @@map("cluster_members")
}

model Channel {
  id            String      @id @default(uuid()) @db.Uuid
  clusterId     String      @map("cluster_id") @db.Uuid
  name          String
  type          ChannelType @default(ASYNC)
  isPrivate     Boolean     @default(false) @map("is_private")
  createdBy     String      @map("created_by") @db.Uuid
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz
  lastMessageAt DateTime?   @map("last_message_at") @db.Timestamptz

  cluster  Cluster   @relation(fields: [clusterId], references: [id])
  creator  User      @relation(fields: [createdBy], references: [id])
  messages Message[]

  @@index([clusterId])
  @@map("channels")
}

model Message {
  id              String    @id @default(uuid()) @db.Uuid
  channelId       String    @map("channel_id") @db.Uuid
  authorUserId    String    @map("author_user_id") @db.Uuid
  authorCabinetId String    @map("author_cabinet_id") @db.Uuid
  content         String
  parentId        String?   @map("parent_id") @db.Uuid
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  channel       Channel           @relation(fields: [channelId], references: [id])
  authorUser    User              @relation("MessageAuthor", fields: [authorUserId], references: [id])
  authorCabinet Cabinet           @relation("MessageCabinet", fields: [authorCabinetId], references: [id])
  parent        Message?          @relation("Thread", fields: [parentId], references: [id])
  replies       Message[]         @relation("Thread")
  reactions     MessageReaction[]
  reports       MessageReport[]

  @@index([channelId])
  @@index([parentId])
  @@index([createdAt])
  @@map("messages")
}

model MessageReaction {
  id        String @id @default(uuid()) @db.Uuid
  messageId String @map("message_id") @db.Uuid
  userId    String @map("user_id") @db.Uuid
  cabinetId String @map("cabinet_id") @db.Uuid
  emoji     String

  message Message @relation(fields: [messageId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
  cabinet Cabinet @relation(fields: [cabinetId], references: [id])

  @@unique([messageId, userId, emoji])
  @@map("message_reactions")
}

model MessageReport {
  id         String       @id @default(uuid()) @db.Uuid
  messageId  String       @map("message_id") @db.Uuid
  reportedBy String       @map("reported_by") @db.Uuid
  reason     String
  status     ReportStatus @default(PENDING)
  createdAt  DateTime     @default(now()) @map("created_at") @db.Timestamptz

  message  Message @relation(fields: [messageId], references: [id])
  reporter User    @relation(fields: [reportedBy], references: [id])

  @@index([status])
  @@map("message_reports")
}

// ──────────────────────────────────────────────────────────────────────────────
// PCA — Plan de Continuité d'Activité
// ──────────────────────────────────────────────────────────────────────────────

/// Stocke l'intégralité du PCA d'un cabinet sous forme JSONB.
/// Une seule ligne par cabinet (relation 1-1).
model CabinetPca {
  id          String    @id @default(uuid()) @db.Uuid
  cabinetId   String    @unique @map("cabinet_id") @db.Uuid
  data        Json      @db.JsonB
  isCompleted Boolean   @default(false) @map("is_completed")
  completedAt DateTime? @map("completed_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  cabinet Cabinet @relation(fields: [cabinetId], references: [id])

  @@index([cabinetId])
  @@map("cabinet_pca")
}

model CabinetPcaHistory {
  id        String   @id @default(cuid())
  cabinetId String   @map("cabinet_id")
  data      Json     @db.JsonB
  savedBy   String   @map("saved_by")
  createdAt DateTime @default(now()) @map("created_at")

  cabinet   Cabinet  @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [savedBy], references: [id], onDelete: Cascade)

  @@index([cabinetId])
  @@map("cabinet_pca_history")
}
