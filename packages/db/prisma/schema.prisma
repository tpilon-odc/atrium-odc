generator client {
  provider      = "prisma-client-js"
  output        = "../generated/client"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ──────────────────────────────────────────────────────────────────────────────
// ENUMS
// ──────────────────────────────────────────────────────────────────────────────

enum GlobalRole {
  cabinet_user
  platform_admin
  regulator
  chamber
  supplier
}

enum SubscriptionStatus {
  active
  trial
  suspended
  cancelled
}

enum MemberRole {
  owner
  admin
  member
}

enum ComplianceItemType {
  doc
  text
  radio
  checkbox
}

enum AnswerStatus {
  draft
  submitted
}

enum ConditionOperator {
  eq
  not_eq
  in
  not_in
}

enum NotificationChannel {
  email
  in_app
}

enum ContactType {
  prospect
  client
  ancien_client
}

enum MaritalStatus {
  celibataire
  marie
  pacse
  divorce
  veuf
}

enum InteractionType {
  email
  appel
  rdv
  note
}

enum StorageMode {
  hosted
  external
}

enum EventType {
  RDV
  CALL
  TASK
  COMPLIANCE
}

enum EventStatus {
  PLANNED
  DONE
  CANCELLED
}

enum StorageProvider {
  aws
  gdrive
  sharepoint
  other
}

enum FolderRuleTagType {
  fixed
  year
  entity_name

  @@map("folder_rule_tag_type")
}

enum DocumentEntityType {
  cabinet
  contact
  product
  supplier
  compliance_answer
  message
}

enum ClusterRole {
  OWNER
  ADMIN
  MEMBER
}

enum ChannelType {
  ASYNC
  REALTIME
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
}

enum ExportStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
  EXPIRED
}

enum ShareEntityType {
  contact
  document
  collaborator_training
  cabinet_compliance
  cabinet
  compliance_item
}

enum GdprRequestType {
  ACCESS
  ERASURE
}

enum GdprRequestStatus {
  PENDING
  PROCESSING
  DONE
  REJECTED
}

// ──────────────────────────────────────────────────────────────────────────────
// AUTH & CABINETS
// ──────────────────────────────────────────────────────────────────────────────

/// Miroir de auth.users — créé automatiquement via trigger Supabase (voir sql/triggers.sql)
model User {
  id         String     @id @db.Uuid
  email      String     @unique
  civility   String?    @map("civility") // "M" | "Mme"
  firstName  String?    @map("first_name")
  lastName   String?    @map("last_name")
  avatarUrl  String?    @map("avatar_url")
  globalRole          GlobalRole @default(cabinet_user) @map("global_role")
  gdprAnonymizedAt    DateTime?  @map("gdpr_anonymized_at") @db.Timestamptz
  createdAt           DateTime   @default(now()) @map("created_at") @db.Timestamptz
  lastLogin           DateTime?  @map("last_login") @db.Timestamptz
  isActive            Boolean    @default(true) @map("is_active")

  cabinetMembers         CabinetMember[]
  complianceAnswers      CabinetComplianceAnswer[]
  suppliersCreated       Supplier[]
  supplierEdits          SupplierEdit[]
  productsCreated        Product[]
  productEdits           ProductEdit[]
  toolsCreated           Tool[]
  toolEdits              ToolEdit[]
  interactions           Interaction[]
  trainingCatalogCreated TrainingCatalog[]
  collaboratorTrainings  CollaboratorTraining[]
  sharesGrantedBy        Share[]                   @relation("GrantedBy")
  sharesGrantedTo        Share[]                   @relation("GrantedTo")
  shareViewLogs          ShareViewLog[]            @relation("ShareViewer")
  notifications          Notification[]
  eventsCreated          Event[]
  clustersCreated        Cluster[]
  channelsCreated        Channel[]
  messages               Message[]         @relation("MessageAuthor")
  messageReactions       MessageReaction[]
  messageReports         MessageReport[]
  exportJobsRequested    ExportJob[]
  consentRecords         ConsentRecord[]
  gdprRequestsMade       GdprRequest[]   @relation("RequestedBy")
  gdprRequestsProcessed  GdprRequest[]   @relation("ProcessedBy")
  pcaHistory             CabinetPcaHistory[]
  supplierUsers          SupplierUser[]

  @@map("users")
}

model Cabinet {
  id                 String             @id @default(uuid()) @db.Uuid
  name               String
  siret              String?
  oriasNumber        String?            @map("orias_number")
  subscriptionStatus SubscriptionStatus @default(trial) @map("subscription_status")
  settings           Json?              @db.JsonB
  description        String?            @db.Text
  city               String?
  website            String?
  logoUrl            String?            @map("logo_url")
  icsToken                String             @unique @default(uuid()) @map("ics_token") @db.Uuid
  deletionRequestedAt     DateTime?          @map("deletion_requested_at") @db.Timestamptz
  deletionScheduledAt     DateTime?          @map("deletion_scheduled_at") @db.Timestamptz
  createdAt               DateTime           @default(now()) @map("created_at") @db.Timestamptz

  members               CabinetMember[]
  complianceAnswers     CabinetComplianceAnswer[]
  complianceNotifs      ComplianceNotification[]
  cabinetSuppliers         CabinetSupplier[]
  supplierEvaluations      CabinetSupplierEvaluation[]
  supplierVerifications    CabinetSupplierVerification[]
  supplierEdits            SupplierEdit[]
  supplierPublicRatings SupplierPublicRating[]
  cabinetProducts       CabinetProduct[]
  productGovernances    CabinetProductGovernance[]
  productEdits          ProductEdit[]
  productPublicRatings  ProductPublicRating[]
  productReviews        ProductReview[]
  supplierReviews       SupplierReview[]
  toolReviews           ToolReview[]
  cabinetTools          CabinetTool[]
  toolEdits             ToolEdit[]
  toolPublicRatings     ToolPublicRating[]
  contacts              Contact[]
  contactProfiles       CabinetContactProfile[]
  storageConfigs        CabinetStorageConfig[]
  documents             Document[]
  folderRules           FolderRule[]
  collaboratorTrainings CollaboratorTraining[]
  shares                Share[]
  notifications         Notification[]
  events                Event[]
  clusterMembers        ClusterMember[]
  messagesAuthored      Message[]         @relation("MessageCabinet")
  messageReactions      MessageReaction[]
  folders               Folder[]
  tags                  Tag[]
  exportJobs            ExportJob[]
  gdprRequests          GdprRequest[]
  pca                   CabinetPca?
  pcaHistory            CabinetPcaHistory[]
  supplierCommercialContacts SupplierCommercialContact[]
  contactProducts            ContactProduct[]
  contactAssets              ContactAsset[]
  contactLiabilities         ContactLiability[]
  contactIncomes             ContactIncome[]
  contactTaxes               ContactTax[]

  @@map("cabinets")
}

model CabinetMember {
  id                String    @id @default(uuid()) @db.Uuid
  cabinetId         String    @map("cabinet_id") @db.Uuid
  userId            String?   @map("user_id") @db.Uuid
  role              MemberRole
  canManageSuppliers Boolean  @default(false) @map("can_manage_suppliers")
  canManageProducts  Boolean  @default(false) @map("can_manage_products")
  canManageContacts  Boolean  @default(false) @map("can_manage_contacts")
  isPublic           Boolean  @default(true) @map("is_public")
  /// Champs pour les membres sans compte plateforme
  externalFirstName  String?  @map("external_first_name")
  externalLastName   String?  @map("external_last_name")
  externalEmail      String?  @map("external_email")
  externalTitle      String?  @map("external_title")
  deletedAt         DateTime? @map("deleted_at") @db.Timestamptz

  cabinet   Cabinet  @relation(fields: [cabinetId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])
  trainings CollaboratorTraining[]

  @@index([cabinetId])
  @@map("cabinet_members")
}

// ──────────────────────────────────────────────────────────────────────────────
// CRM — SITUATION PATRIMONIALE
// ──────────────────────────────────────────────────────────────────────────────

/// Actifs du contact (immobilier, financier, professionnel, autre)
model ContactAsset {
  id             String   @id @default(uuid()) @db.Uuid
  cabinetId      String   @map("cabinet_id") @db.Uuid
  contactId      String   @map("contact_id") @db.Uuid
  type           String   // immobilier | financier | professionnel | autre
  label          String
  estimatedValue Float    @map("estimated_value")
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  cabinet Cabinet @relation(fields: [cabinetId], references: [id])
  contact Contact @relation(fields: [contactId], references: [id])

  @@index([cabinetId, contactId])
  @@map("contact_assets")
}

/// Passifs du contact (crédits en cours)
model ContactLiability {
  id               String    @id @default(uuid()) @db.Uuid
  cabinetId        String    @map("cabinet_id") @db.Uuid
  contactId        String    @map("contact_id") @db.Uuid
  type             String    // immobilier | consommation | professionnel | autre
  label            String
  outstandingAmount Float    @map("outstanding_amount")
  monthlyPayment   Float?   @map("monthly_payment")
  endDate          DateTime? @map("end_date") @db.Date
  notes            String?
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz

  cabinet Cabinet @relation(fields: [cabinetId], references: [id])
  contact Contact @relation(fields: [contactId], references: [id])

  @@index([cabinetId, contactId])
  @@map("contact_liabilities")
}

/// Revenus du contact (par source)
model ContactIncome {
  id           String   @id @default(uuid()) @db.Uuid
  cabinetId    String   @map("cabinet_id") @db.Uuid
  contactId    String   @map("contact_id") @db.Uuid
  type         String   // salaire | foncier | dividendes | pension | autre
  label        String
  annualAmount Float    @map("annual_amount")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  cabinet Cabinet @relation(fields: [cabinetId], references: [id])
  contact Contact @relation(fields: [contactId], references: [id])

  @@index([cabinetId, contactId])
  @@map("contact_incomes")
}

/// Fiscalité du contact (ligne unique par contact par cabinet)
model ContactTax {
  id          String   @id @default(uuid()) @db.Uuid
  cabinetId   String   @map("cabinet_id") @db.Uuid
  contactId   String   @map("contact_id") @db.Uuid
  tmi         Float?                          // tranche marginale d'imposition (0.11, 0.30, 0.41, 0.45)
  regime      String?                         // ir | is
  pfuOption   Boolean  @default(false) @map("pfu_option")
  ifi         Boolean  @default(false)        // assujetti IFI
  ifiValue    Float?   @map("ifi_value")      // valeur du patrimoine taxable IFI
  notes       String?
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  cabinet Cabinet @relation(fields: [cabinetId], references: [id])
  contact Contact @relation(fields: [contactId], references: [id])

  @@unique([cabinetId, contactId])
  @@map("contact_taxes")
}

/// Produits effectivement vendus à un contact par un cabinet
model ContactProduct {
  id        String   @id @default(uuid()) @db.Uuid
  cabinetId String   @map("cabinet_id") @db.Uuid
  contactId String   @map("contact_id") @db.Uuid
  productId String   @map("product_id") @db.Uuid
  soldAt    DateTime @map("sold_at") @db.Date
  amount    Float?
  notes     String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  cabinet Cabinet @relation(fields: [cabinetId], references: [id])
  contact Contact @relation(fields: [contactId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([cabinetId, contactId])
  @@map("contact_products")
}

model ConsentRecord {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  version     String
  acceptedAt  DateTime @default(now()) @map("accepted_at") @db.Timestamptz
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("consent_records")
}

model GdprRequest {
  id           String            @id @default(uuid()) @db.Uuid
  cabinetId    String            @map("cabinet_id") @db.Uuid
  requestedBy  String            @map("requested_by") @db.Uuid
  type         GdprRequestType
  status       GdprRequestStatus @default(PENDING)
  message      String?
  processedBy  String?           @map("processed_by") @db.Uuid
  processedAt  DateTime?         @map("processed_at") @db.Timestamptz
  response     String?
  exportPath   String?           @map("export_path")
  createdAt    DateTime          @default(now()) @map("created_at") @db.Timestamptz

  cabinet     Cabinet @relation(fields: [cabinetId], references: [id])
  requester   User    @relation("RequestedBy", fields: [requestedBy], references: [id])
  processor   User?   @relation("ProcessedBy", fields: [processedBy], references: [id])

  @@index([cabinetId])
  @@index([status])
  @@map("gdpr_requests")
}

// ──────────────────────────────────────────────────────────────────────────────
// CONFORMITÉ
// ──────────────────────────────────────────────────────────────────────────────

model CompliancePhase {
  id          String   @id @default(uuid()) @db.Uuid
  label       String
  description String?
  order       Int
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  items ComplianceItem[]

  @@map("compliance_phases")
}

model ComplianceItem {
  id                 String             @id @default(uuid()) @db.Uuid
  phaseId            String             @map("phase_id") @db.Uuid
  label              String
  type               ComplianceItemType
  config             Json               @db.JsonB
  isRequired         Boolean            @default(true) @map("is_required")
  validityMonths     Int?               @map("validity_months")
  alertBeforeDays    Int[]              @map("alert_before_days")
  dueDaysAfterSignup Int?               @map("due_days_after_signup")
  order              Int

  phase      CompliancePhase           @relation(fields: [phaseId], references: [id])
  conditions ComplianceCondition[]     @relation("ConditionedItem")
  dependedBy ComplianceCondition[]     @relation("DependsOnItem")
  answers    CabinetComplianceAnswer[]

  @@index([phaseId])
  @@map("compliance_items")
}

model ComplianceCondition {
  id              String            @id @default(uuid()) @db.Uuid
  itemId          String            @map("item_id") @db.Uuid
  dependsOnItemId String            @map("depends_on_item_id") @db.Uuid
  operator        ConditionOperator
  expectedValue   String            @map("expected_value")

  item      ComplianceItem @relation("ConditionedItem", fields: [itemId], references: [id])
  dependsOn ComplianceItem @relation("DependsOnItem", fields: [dependsOnItemId], references: [id])

  @@index([itemId])
  @@map("compliance_conditions")
}

model CabinetComplianceAnswer {
  id          String       @id @default(uuid()) @db.Uuid
  cabinetId   String       @map("cabinet_id") @db.Uuid
  itemId      String       @map("item_id") @db.Uuid
  answeredBy  String       @map("answered_by") @db.Uuid
  value       Json         @db.JsonB
  status      AnswerStatus @default(draft)
  submittedAt DateTime?    @map("submitted_at") @db.Timestamptz
  expiresAt   DateTime?    @map("expires_at") @db.Timestamptz
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime?    @map("deleted_at") @db.Timestamptz

  cabinet       Cabinet                @relation(fields: [cabinetId], references: [id])
  item          ComplianceItem         @relation(fields: [itemId], references: [id])
  user          User                   @relation(fields: [answeredBy], references: [id])
  notifications ComplianceNotification[]
  events        Event[]

  @@unique([cabinetId, itemId])
  @@index([cabinetId])
  @@index([expiresAt])
  @@map("cabinet_compliance_answers")
}

model ComplianceNotification {
  id         String              @id @default(uuid()) @db.Uuid
  cabinetId  String              @map("cabinet_id") @db.Uuid
  answerId   String              @map("answer_id") @db.Uuid
  daysBefore Int                 @map("days_before")
  channel    NotificationChannel
  sentAt     DateTime            @map("sent_at") @db.Timestamptz

  cabinet Cabinet                 @relation(fields: [cabinetId], references: [id])
  answer  CabinetComplianceAnswer @relation(fields: [answerId], references: [id])

  @@index([cabinetId])
  @@index([answerId, daysBefore])
  @@map("compliance_notifications")
}

// ──────────────────────────────────────────────────────────────────────────────
// BASE COMMUNAUTAIRE — FOURNISSEURS
// ──────────────────────────────────────────────────────────────────────────────

model Supplier {
  id              String    @id @default(uuid()) @db.Uuid
  name            String
  description     String?
  category        String?
  website         String?
  email           String?
  phone           String?
  createdBy       String    @map("created_by") @db.Uuid
  avgPublicRating Float?    @map("avg_public_rating")
  isVerified      Boolean   @default(false) @map("is_verified")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz

  creator          User                          @relation(fields: [createdBy], references: [id])
  edits            SupplierEdit[]
  cabinetSuppliers CabinetSupplier[]
  publicRatings    SupplierPublicRating[]
  productLinks     ProductSupplier[]
  reviews          SupplierReview[]
  supplierUsers    SupplierUser[]
  documents        Document[]
  evaluations          CabinetSupplierEvaluation[]
  verifications        CabinetSupplierVerification[]
  commercialContacts   SupplierCommercialContact[]

  @@index([createdAt])
  @@map("suppliers")
}

model SupplierCommercialContact {
  id         String   @id @default(uuid()) @db.Uuid
  cabinetId  String   @map("cabinet_id") @db.Uuid
  supplierId String   @map("supplier_id") @db.Uuid
  firstName  String   @map("first_name")
  lastName   String   @map("last_name")
  phone      String?
  email      String?
  region     String?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  cabinet  Cabinet  @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([cabinetId, supplierId])
  @@map("supplier_commercial_contacts")
}

model SupplierUser {
  id         String   @id @default(uuid()) @db.Uuid
  supplierId String   @map("supplier_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([supplierId, userId])
  @@index([userId])
  @@map("supplier_users")
}

model SupplierEdit {
  id         String   @id @default(uuid()) @db.Uuid
  supplierId String   @map("supplier_id") @db.Uuid
  editedBy   String   @map("edited_by") @db.Uuid
  cabinetId  String   @map("cabinet_id") @db.Uuid
  diff       Json     @db.JsonB
  editedAt   DateTime @default(now()) @map("edited_at") @db.Timestamptz

  supplier Supplier @relation(fields: [supplierId], references: [id])
  editor   User     @relation(fields: [editedBy], references: [id])
  cabinet  Cabinet  @relation(fields: [cabinetId], references: [id])

  @@index([supplierId])
  @@map("supplier_edits")
}

model CabinetSupplier {
  id            String    @id @default(uuid()) @db.Uuid
  cabinetId     String    @map("cabinet_id") @db.Uuid
  supplierId    String    @map("supplier_id") @db.Uuid
  isActive      Boolean   @default(true) @map("is_active")
  privateRating Int?      @map("private_rating")
  privateNote   String?   @map("private_note")
  internalTags  String[]  @map("internal_tags")
  customFields  Json?     @db.JsonB @map("custom_fields")
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz

  cabinet      Cabinet                      @relation(fields: [cabinetId], references: [id])
  supplier     Supplier                     @relation(fields: [supplierId], references: [id])
  verification CabinetSupplierVerification?

  @@unique([cabinetId, supplierId])
  @@index([cabinetId])
  @@map("cabinet_suppliers")
}

model CabinetSupplierEvaluation {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cabinetId           String    @map("cabinet_id") @db.Uuid
  supplierId          String    @map("supplier_id") @db.Uuid

  evaluationNotes     Json      @default("[]") @map("evaluation_notes")
  scoreGlobal         Decimal?  @map("score_global") @db.Decimal(3, 2)

  evaluationDate      DateTime  @default(now()) @map("evaluation_date") @db.Date
  nextReviewDate      DateTime? @map("next_review_date") @db.Date
  evaluateurIds       String[]  @map("evaluateurs")
  contratSigneLe      DateTime? @map("contrat_signe_le") @db.Date
  contratDuree        String?   @map("contrat_duree")
  contratPreavis      String?   @map("contrat_preavis")
  contratDocumentId   String?   @map("contrat_document_id") @db.Uuid

  status              String    @default("draft")
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  cabinet  Cabinet  @relation(fields: [cabinetId], references: [id])
  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@index([cabinetId, supplierId])
  @@index([nextReviewDate])
  @@map("cabinet_supplier_evaluations")
}

model CabinetSupplierVerification {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cabinetId             String    @map("cabinet_id") @db.Uuid
  supplierId            String    @map("supplier_id") @db.Uuid
  supplierType          String    @map("supplier_type")
  checklist             Json      @default("[]")
  beneficiairesVerifies Boolean   @default(false) @map("beneficiaires_verifies")
  beneficiairesSource   String?   @map("beneficiaires_source")
  verificationDate      DateTime? @map("verification_date") @db.Date
  verifiedBy            String?   @map("verified_by") @db.Uuid
  decision              String?
  decisionNote          String?   @map("decision_note")
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  cabinet         Cabinet         @relation(fields: [cabinetId], references: [id])
  supplier        Supplier        @relation(fields: [supplierId], references: [id])
  cabinetSupplier CabinetSupplier @relation(fields: [cabinetId, supplierId], references: [cabinetId, supplierId])

  @@unique([cabinetId, supplierId])
  @@index([cabinetId])
  @@map("cabinet_supplier_verification")
}

/// 1 note publique par cabinet par fournisseur — avg_public_rating recalculé par trigger
model SupplierPublicRating {
  id         String   @id @default(uuid()) @db.Uuid
  supplierId String   @map("supplier_id") @db.Uuid
  cabinetId  String   @map("cabinet_id") @db.Uuid
  rating     Int
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  supplier Supplier @relation(fields: [supplierId], references: [id])
  cabinet  Cabinet  @relation(fields: [cabinetId], references: [id])

  @@unique([supplierId, cabinetId])
  @@index([supplierId])
  @@map("supplier_public_ratings")
}

// ──────────────────────────────────────────────────────────────────────────────
// BASE COMMUNAUTAIRE — PRODUITS
// ──────────────────────────────────────────────────────────────────────────────

model Product {
  id              String    @id @default(uuid()) @db.Uuid
  name            String
  description     String?
  category        String?
  website         String?
  createdBy       String    @map("created_by") @db.Uuid
  avgPublicRating Float?    @map("avg_public_rating")
  isVerified      Boolean   @default(false) @map("is_verified")
  isActive        Boolean   @default(true) @map("is_active")
  mainCategory    String?   @map("main_category")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
