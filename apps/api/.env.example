# Supabase
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Base de données directe (Prisma)
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
DIRECT_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Redis
REDIS_URL=redis://localhost:6379

# MinIO / S3
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=cgp-documents

# Email
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
MAIL_FROM=CGP Platform <noreply@cgp-platform.fr>

# App
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:3001

# Versions CGU / Politique de confidentialité (date ISO)
CGU_VERSION=2026-03-01
PRIVACY_VERSION=2026-03-01

# RGPD
GDPR_ADMIN_EMAIL=admin@cgp-platform.fr

# Utilisateur système (UUID du compte plateforme pour les opérations automatiques)
SYSTEM_USER_ID=

# Webhook Odoo (optionnel)
ODOO_WEBHOOK_SECRET=

# Web Push (VAPID) — générer avec: node -e "const wp=require('web-push');const k=wp.generateVAPIDKeys();console.log(k)"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@cgp-platform.fr
