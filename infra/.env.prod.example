# ─────────────────────────────────────────────────────────────
# myGaïa Platform — Variables d'environnement production
# Copier ce fichier en .env.prod et remplir toutes les valeurs
# NE JAMAIS committer .env.prod dans git
# ─────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────
# URL de votre instance Supabase self-hosted (ex: https://supabase.mygaia.fr)
SUPABASE_URL=https://supabase.mygaia.fr
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── API ───────────────────────────────────────────────────────
# URL publique de l'API (utilisée par le frontend)
API_URL=https://api.mygaia.fr

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change-me-strong-random-secret-min-32-chars

# ── MinIO (stockage documents) ───────────────────────────────
MINIO_ACCESS_KEY=change-me-minio-admin
MINIO_SECRET_KEY=change-me-minio-password-min-8-chars
MINIO_BUCKET=cgp-documents

# ── SMTP ─────────────────────────────────────────────────────
# En prod : remplacer par votre serveur SMTP réel
# En dev/test : laisser vide pour utiliser Mailpit (localhost:1025)
SMTP_HOST=smtp.votre-fournisseur.fr
SMTP_PORT=587
SMTP_USER=no-reply@mygaia.fr
SMTP_PASS=your-smtp-password
