# ─────────────────────────────────────────────────────────────
# myGaïa Platform — Variables d'environnement production
# Copier ce fichier en .env.prod et remplir toutes les valeurs
# NE JAMAIS committer .env.prod dans git
# ─────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=http://<IP_SERVEUR>:8000
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Next.js build-time (inliné dans le bundle JS — rebuild requis si changement) ──
# NEXT_PUBLIC_API_URL = URL de base sans /api (le code ajoute /api/v1/...)
NEXT_PUBLIC_API_URL=http://<IP_SERVEUR>
NEXT_PUBLIC_SUPABASE_URL=http://<IP_SERVEUR>:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── API ───────────────────────────────────────────────────────
API_URL=http://<IP_SERVEUR>/api
FRONTEND_URL=http://<IP_SERVEUR>
JWT_SECRET=change-me-strong-random-secret-min-32-chars

# ── Base de données (connexion directe Postgres) ─────────────
DATABASE_URL=postgresql://postgres:<POSTGRES_PASSWORD>@supabase-db:5432/postgres
DIRECT_URL=postgresql://postgres:<POSTGRES_PASSWORD>@supabase-db:5432/postgres

# ── MinIO (stockage documents) ───────────────────────────────
MINIO_ACCESS_KEY=change-me-minio-admin
MINIO_SECRET_KEY=change-me-minio-password-min-8-chars
MINIO_BUCKET=cgp-documents

# ── SMTP ─────────────────────────────────────────────────────
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
